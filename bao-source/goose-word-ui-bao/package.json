{
  "name": "@baohaus/goose-word-ui-bao",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "build:css": "bun run scripts/build-css.ts",
    "bao:build": "bun run build:css && bun run bao:validate",
    "bao:validate": "bun run scripts/bao-validate.ts"
  },
  "exports": {
    "./manifest": {
      "bun": "./src/manifest.ts",
      "import": "./src/manifest.ts",
      "types": "./src/manifest.ts",
      "default": "./src/manifest.ts"
    }
  },
  "files": [
    "public",
    "scripts",
    "src",
    "README.md"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@tailwindcss/cli": "4.1.8",
    "daisyui": "5.0.50",
    "tailwindcss": "4.1.8"
  }
}
