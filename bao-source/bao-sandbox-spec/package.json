  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "license": "UNLICENSED",
  "description": "Canonical .bao sandbox manifest schema, TypeScript shape, and validator → JailSpec compiler.",
  "dependencies": {
    "@baohaus/bao-constants": "0.1.0",
    "@baohaus/bao-bpf": "0.1.0",
