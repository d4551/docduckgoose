      "default": "./dist/usage.js"
    },
    "./grant-signer": {
      "bun": "./dist/grant-signer.js",
      "import": "./dist/grant-signer.js",
      "types": "./dist/grant-signer.d.ts",
      "default": "./dist/grant-signer.js"
    },
    "./scheduler": {
      "bun": "./dist/scheduler.js",
      "import": "./dist/scheduler.js",
      "types": "./dist/scheduler.d.ts",
      "default": "./dist/scheduler.js"
    },
    "./cluster": {
      "bun": "./dist/cluster.js",
