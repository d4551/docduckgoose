{
  "name": "@baohaus/bao-sandbox-spec",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "build": "bun run ./scripts/build.ts",
    "typecheck": "bunx --bun tsc --noEmit --project tsconfig.json",
    "test": "bun test",
    "lint": "bunx --bun biome check --error-on-warnings .",
    "bao:build": "bun run ./scripts/bao-build.ts",
    "bao:validate": "bun run ./scripts/bao-validate.ts",
    "verify": "bun run typecheck && bun run lint && bun test"
  },
  "exports": {
    "./schema": {
      "bun": "./dist/schema.js",
      "import": "./dist/schema.js",
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    },
    "./validate": {
      "bun": "./dist/validate.js",
      "import": "./dist/validate.js",
      "types": "./dist/validate.d.ts",
      "default": "./dist/validate.js"
    },
    "./compile": {
      "bun": "./dist/compile.js",
      "import": "./dist/compile.js",
      "types": "./dist/compile.d.ts",
      "default": "./dist/compile.js"
    },
    "./wire-resize": {
      "bun": "./dist/wire-resize.js",
