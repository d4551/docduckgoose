      "types": "./dist/wire-resize.d.ts",
      "default": "./dist/wire-resize.js"
    },
    "./package-descriptor": {
      "bun": "./dist/package-descriptor.js",
      "import": "./dist/package-descriptor.js",
      "types": "./dist/package-descriptor.d.ts",
      "default": "./dist/package-descriptor.js"
    },
    "./events": {
      "bun": "./dist/events.js",
      "import": "./dist/events.js",
      "types": "./dist/events.d.ts",
      "default": "./dist/events.js"
    },
    "./event-bus": {
      "bun": "./dist/event-bus.js",
      "import": "./dist/event-bus.js",
      "types": "./dist/event-bus.d.ts",
      "default": "./dist/event-bus.js"
    },
    "./matrix": {
      "bun": "./dist/matrix.js",
      "import": "./dist/matrix.js",
      "types": "./dist/matrix.d.ts",
      "default": "./dist/matrix.js"
    },
    "./resources": {
      "bun": "./dist/resources.js",
      "import": "./dist/resources.js",
      "types": "./dist/resources.d.ts",
      "default": "./dist/resources.js"
    },
    "./capabilities": {
      "bun": "./dist/capabilities.js",
      "import": "./dist/capabilities.js",
      "types": "./dist/capabilities.d.ts",
      "default": "./dist/capabilities.js"
    },
    "./grants": {
      "bun": "./dist/grants.js",
