{
  "name": "@baohaus/libsql-bao",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "description": "LibSQL client parity: HTTP and WebSocket protocols, batch, transactions",
  "scripts": {
    "build": "bun run ./scripts/build.ts",
    "typecheck": "bunx --bun tsc --noEmit --project tsconfig.json",
    "test": "bun test",
    "lint": "bunx --bun @biomejs/biome check --error-on-warnings .",
    "bao:build": "bun run ./scripts/bao-build.ts",
    "bao:validate": "bun run ./scripts/bao-validate.ts",
    "verify": "bun run typecheck && bun run lint && bun test && bun run build && bun run bao:build && bun run bao:validate"
  },
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "bun": "./dist/client.js",
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./sqlite": {
      "bun": "./dist/sqlite.js",
      "import": "./dist/sqlite.js",
      "types": "./dist/sqlite.d.ts",
      "default": "./dist/sqlite.js"
    },
    "./batch": {
      "bun": "./dist/batch.js",
      "import": "./dist/batch.js",
      "types": "./dist/batch.d.ts",
      "default": "./dist/batch.js"
    },
    "./transaction": {
      "bun": "./dist/transaction.js",
      "import": "./dist/transaction.js",
      "types": "./dist/transaction.d.ts",
      "default": "./dist/transaction.js"
    },
    "./types": {
      "bun": "./dist/types.js",
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "UNLICENSED",
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "1.3.13",
    "typescript": "6.0.3"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
