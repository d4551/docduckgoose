{
  "name": "@baohaus/ecosystem-events-bao",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "description": "Canonical in-process pub/sub bus + SSE encoder + per-subscriber filter for cross-surface contribution-change signals (sidebar / settings-tab / palette-entry-group / api-group / tile-group). Consumed by every Bao app's SSE sink so a `.bao` install or capability re-evaluation fans out to every open browser tab without a page reload.",
  "exports": {
    "./service": {
      "bun": "./src/service.ts",
      "import": "./src/service.ts",
      "types": "./src/service.ts",
      "default": "./src/service.ts"
    },
    "./types": {
      "bun": "./src/types.ts",
      "import": "./src/types.ts",
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./encoder": {
      "bun": "./dist/encoder.js",
      "import": "./dist/encoder.js",
      "types": "./dist/encoder.d.ts",
      "default": "./dist/encoder.js"
    },
    "./filter": {
      "bun": "./dist/filter.js",
      "import": "./dist/filter.js",
      "types": "./dist/filter.d.ts",
      "default": "./dist/filter.js"
    },
    "./sse-sink": {
      "bun": "./dist/sse-sink.js",
      "import": "./dist/sse-sink.js",
      "types": "./dist/sse-sink.d.ts",
      "default": "./dist/sse-sink.js"
    },
    "./bridge": {
      "bun": "./dist/bridge.js",
      "import": "./dist/bridge.js",
      "types": "./dist/bridge.d.ts",
      "default": "./dist/bridge.js"
    },
    "./baoboss-transport": {
      "bun": "./dist/baoboss-transport.js",
      "import": "./dist/baoboss-transport.js",
      "types": "./dist/baoboss-transport.d.ts",
      "default": "./dist/baoboss-transport.js"
    },
    "./install-boot": {
      "bun": "./dist/install-boot.js",
      "import": "./dist/install-boot.js",
      "types": "./dist/install-boot.d.ts",
      "default": "./dist/install-boot.js"
    },
    "./install-boot-with-baoboss": {
      "bun": "./dist/install-boot-with-baoboss.js",
      "import": "./dist/install-boot-with-baoboss.js",
      "types": "./dist/install-boot-with-baoboss.d.ts",
      "default": "./dist/install-boot-with-baoboss.js"
    },
    "./peer-invalidation": {
      "bun": "./dist/peer-invalidation.js",
      "import": "./dist/peer-invalidation.js",
      "types": "./dist/peer-invalidation.d.ts",
      "default": "./dist/peer-invalidation.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun run ./scripts/build.ts",
    "typecheck": "bunx --bun tsc --noEmit --project tsconfig.json",
    "test": "bun test",
    "lint": "bunx --bun biome check --error-on-warnings .",
    "bao:build": "bun run ./scripts/bao-build.ts",
    "bao:validate": "bun run ./scripts/bao-validate.ts",
    "verify": "bun run typecheck && bun run lint && bun test"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@baohaus/bao-boss": "0.1.11",
    "@baohaus/bao-utils": "0.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "1.3.13",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
