{
  "name": "@baohaus/dayjs-bao",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "description": "Day.js parity: parsing, manipulation, formatting, locales, plugins, duration",
  "scripts": {
    "build": "bun run ./scripts/build.ts",
    "typecheck": "bunx --bun tsc --noEmit --project tsconfig.json",
    "test": "bun test",
    "lint": "bunx --bun @biomejs/biome check --error-on-warnings .",
    "bao:build": "bun run ./scripts/bao-build.ts",
    "bao:validate": "bun run ./scripts/bao-validate.ts",
    "verify": "bun run typecheck && bun run lint && bun test && bun run build && bun run bao:build && bun run bao:validate"
  },
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./parse": {
      "bun": "./dist/parse.js",
      "import": "./dist/parse.js",
      "types": "./dist/parse.d.ts",
      "default": "./dist/parse.js"
    },
    "./format": {
      "bun": "./dist/format.js",
      "import": "./dist/format.js",
      "types": "./dist/format.d.ts",
      "default": "./dist/format.js"
    },
    "./duration": {
      "bun": "./dist/duration.js",
      "import": "./dist/duration.js",
      "types": "./dist/duration.d.ts",
      "default": "./dist/duration.js"
    },
    "./locale": {
      "bun": "./dist/locale.js",
      "import": "./dist/locale.js",
      "types": "./dist/locale.d.ts",
      "default": "./dist/locale.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "UNLICENSED",
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "1.3.13",
    "typescript": "6.0.3"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
