{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "types": ["bun"],
    "rewriteRelativeImportExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*"],
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "__tests__",
    "dist",
    "node_modules",
    "scripts",
    "tests"
  ],
  "extends": "./tsconfig.package.json"
}
