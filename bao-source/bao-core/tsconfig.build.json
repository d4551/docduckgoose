{
  "extends": "./tsconfig.package.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "sourceMap": true,
    "paths": {
      "@baohaus/bao-core/*": ["./src/*"],
      "@shared/*": ["./libs/shared/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "dist",
    "node_modules",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/validation/integration.ts",
    "src/validation/ui.ts",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "__tests__",
    "scripts",
    "tests"
  ]
}
