{
  "name": "@baohaus/goose-word-native-shell-bao",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "description": "Capacitor native shell for Goose Word (Android compiled Bun binary, iOS in-process loopback host).",
  "scripts": {
    "build": "bun run ./scripts/bao-build.ts",
    "typecheck": "bunx --bun tsc --noEmit --project tsconfig.json",
    "cap:sync": "bun run ./scripts/cap-sync.ts",
    "android:assemble": "bun run ./scripts/android-assemble.ts",
    "ios:archive": "bun run ./scripts/ios-archive.ts",
    "bao:validate": "bun run ./scripts/bao-validate.ts"
  },
  "dependencies": {
    "@capacitor/android": "7.2.0",
    "@capacitor/core": "7.2.0",
    "@capacitor/ios": "7.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "7.2.0",
    "@types/bun": "1.3.14",
    "typescript": "6.0.3"
  }
}
