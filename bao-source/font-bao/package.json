{
  "name": "@baohaus/font-bao",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "description": "Self-hosted font packages with CSS @font-face generation and vendored woff assets",
  "scripts": {
    "build": "bun run ./scripts/build.ts",
    "create-handwriting": "bun run ./scripts/create-handwriting-font.ts",
    "typecheck": "bunx --bun tsc --noEmit --project tsconfig.json",
    "test": "bun test",
    "lint": "bunx --bun @biomejs/biome check --error-on-warnings .",
    "bao:build": "bun run ./scripts/bao-build.ts",
    "bao:validate": "bun run ./scripts/bao-validate.ts",
    "verify": "bun run typecheck && bun run lint && bun test && bun run build && bun run bao:build && bun run bao:validate"
  },
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./manifest": {
      "bun": "./dist/manifest.js",
      "import": "./dist/manifest.js",
      "types": "./dist/manifest.d.ts",
      "default": "./dist/manifest.js"
    },
    "./inter": {
      "bun": "./dist/inter.js",
      "import": "./dist/inter.js",
      "types": "./dist/inter.d.ts",
      "default": "./dist/inter.js"
    },
    "./jetbrains-mono": {
      "bun": "./dist/jetbrains-mono.js",
      "import": "./dist/jetbrains-mono.js",
      "types": "./dist/jetbrains-mono.d.ts",
      "default": "./dist/jetbrains-mono.js"
    },
    "./syne": {
      "bun": "./dist/syne.js",
      "import": "./dist/syne.js",
      "types": "./dist/syne.d.ts",
      "default": "./dist/syne.js"
    },
    "./dm-sans": {
      "bun": "./dist/dm-sans.js",
      "import": "./dist/dm-sans.js",
      "types": "./dist/dm-sans.d.ts",
      "default": "./dist/dm-sans.js"
    },
    "./ibm-plex-mono": {
      "bun": "./dist/ibm-plex-mono.js",
      "import": "./dist/ibm-plex-mono.js",
      "types": "./dist/ibm-plex-mono.d.ts",
      "default": "./dist/ibm-plex-mono.js"
    },
    "./instrument-serif": {
      "bun": "./dist/instrument-serif.js",
      "import": "./dist/instrument-serif.js",
      "types": "./dist/instrument-serif.d.ts",
      "default": "./dist/instrument-serif.js"
    },
    "./playfair-display": {
      "bun": "./dist/playfair-display.js",
      "import": "./dist/playfair-display.js",
      "types": "./dist/playfair-display.d.ts",
      "default": "./dist/playfair-display.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "UNLICENSED",
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@fontsource/dm-sans": "5.2.8",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@fontsource/instrument-serif": "5.2.8",
    "@fontsource/playfair-display": "5.2.8",
    "@fontsource/syne": "5.2.7",
    "@types/bun": "1.3.13",
    "@types/opentype.js": "^1.3.9",
    "opentype.js": "^2.0.0",
    "sharp": "^0.34.5",
    "typescript": "6.0.3",
    "wawoff2": "^2.0.1"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
