{
  "name": "@baohaus/json-gyoza",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "build": "bun run ./scripts/build.ts",
    "typecheck": "bunx --bun tsc --noEmit --project tsconfig.json",
    "test": "bun test",
    "lint": "bunx --bun biome check --error-on-warnings .",
    "bao:build": "bun run ./scripts/bao-build.ts",
    "bao:validate": "bun run ./scripts/bao-validate.ts",
    "verify": "bun run typecheck && bun run lint && bun test"
  },
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package-descriptor": {
      "bun": "./dist/package-descriptor.js",
      "import": "./dist/package-descriptor.js",
      "types": "./dist/package-descriptor.d.ts",
      "default": "./dist/package-descriptor.js"
    },
    "./jsonc": {
      "bun": "./dist/jsonc.js",
      "import": "./dist/jsonc.js",
      "types": "./dist/jsonc.d.ts",
      "default": "./dist/jsonc.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "license": "UNLICENSED",
  "description": "Tiny JSON value helpers for Baohaus transport internals.",
  "dependencies": {
    "@baohaus/bao-json-safe": "0.1.0",
    "@baohaus/bao-utils": "0.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "1.3.13",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.13"
}
