{
  "name": "@baohaus/goose-word",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "link:bao": "bun run ./scripts/link-local-bao-deps.ts",
    "dev": "bun run link:bao && bun --watch src/main.ts",
    "start": "bun run link:bao && bun src/main.ts",
    "typecheck": "bunx --bun tsc --noEmit --project tsconfig.json",
    "test": "bun test",
    "build:arm64": "bun run scripts/build-linux-arm64.ts",
    "mobile:server:android": "bun run scripts/build-android-arm64.ts",
    "mobile:sync": "bun run --cwd ../bao-source/goose-word-native-shell-bao cap:sync",
    "mobile:android:assemble": "bun run --cwd ../bao-source/goose-word-native-shell-bao android:assemble",
    "mobile:ios:archive": "bun run --cwd ../bao-source/goose-word-native-shell-bao ios:archive",
    "mobile:offline:proof": "bun run scripts/mobile-offline-proof.ts",
    "bao:build": "bun run ./scripts/bao-build.ts",
    "bao:validate": "bun run ./scripts/bao-validate.ts",
    "bao:validate:gates": "bun run ./scripts/bao-validate-gates.ts",
    "validate:strict": "bun run typecheck && bun run test && bun run bao:validate:gates"
  },
  "dependencies": {
    "@baohaus/bao-install-handlers-bao": "file:../bao-source/bao-install-handlers-bao",
    "@baohaus/bao-sdk": "file:../bao-source/bao-sdk",
    "@baohaus/contribution-registry-bao": "file:../bao-source/contribution-registry-bao",
    "@baohaus/bao-json-safe": "0.1.0",
    "@baohaus/baohaus-density-preset-aurora-bao": "0.1.0",
    "@baohaus/baohaus-design-tokens-aurora-bao": "0.1.0",
    "@baohaus/baohaus-theme-aurora-light-bao": "0.1.0",
    "@baohaus/font-bao": "0.1.0",
    "@baohaus/goose-word-ui-bao": "0.1.0",
    "@baohaus/htmx-vendor-bao": "0.1.0",
    "@baohaus/markdown-bao": "0.1.0",
    "@baohaus/sanitize-bao": "0.1.0",
    "@baohaus/soy-view-kit": "0.1.0",
    "@baohaus/spellcheck-bao": "0.1.0",
    "@baohaus/tangyuan-i18n": "0.1.0",
    "elysia": "1.4.28"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "typescript": "6.0.3"
  }
}
