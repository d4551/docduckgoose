{
  "name": "@baohaus/goose-word",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "typecheck": "bunx --bun tsc --noEmit --project tsconfig.json",
    "test": "bun test",
    "build:arm64": "bun run scripts/build-linux-arm64.ts",
    "bao:build": "bun run ./scripts/bao-build.ts",
    "bao:validate": "bun run ./scripts/bao-validate.ts"
  },
  "dependencies": {
    "@baohaus/bao-json-safe": "0.1.0",
    "@baohaus/baohaus-density-preset-aurora-bao": "0.1.0",
    "@baohaus/baohaus-design-tokens-aurora-bao": "0.1.0",
    "@baohaus/baohaus-theme-aurora-light-bao": "0.1.0",
    "@baohaus/font-bao": "0.1.0",
    "@baohaus/goose-word-ui-bao": "0.1.0",
    "@baohaus/htmx-vendor-bao": "0.1.0",
    "@baohaus/markdown-bao": "0.1.0",
    "@baohaus/sanitize-bao": "0.1.0",
    "@baohaus/soy-view-kit": "0.1.0",
    "@baohaus/spellcheck-bao": "0.1.0",
    "@baohaus/tangyuan-i18n": "0.1.0",
    "elysia": "1.4.28"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "typescript": "6.0.3"
  }
}
