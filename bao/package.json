{
  "name": "@baohaus/bao-package-kit",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "description": "Spec, build, validate, and policy authority for Baohaus bao-governance.json, bao.lock, and .bao archives.",
  "scripts": {
    "build": "bun run typecheck",
    "typecheck": "bunx --bun tsc --noEmit --project tsconfig.json",
    "lint": "bunx --bun @biomejs/biome check --error-on-warnings .",
    "test": "bun test",
    "bao:build": "bun run ./scripts/bao-build.ts",
    "bao:validate": "bun run ./scripts/bao-validate.ts",
    "bao:resolve": "bun run ./scripts/bao-resolve.ts",
    "validate:no-workspace-package-hoarding": "bun run ./scripts/validate-no-workspace-package-hoarding.ts",
    "validate:registry-parity": "bun run ./scripts/validate-registry-parity.ts",
    "validate:manifest-parity": "bun run ./scripts/validate-manifest-parity.ts @baohaus/bao-package-kit",
    "validate:registry-consumption": "bun run ./scripts/validate-registry-consumption.ts",
    "validate:runtime-consumption": "bun run ./scripts/validate-runtime-consumption.ts",
    "validate:package-repos-parity": "bun run ./scripts/validate-package-repos-parity.ts",
    "validate:no-workspace-deps": "bun run ./scripts/validate-no-workspace-deps.ts",
    "validate:catalog-schema": "bun run ./scripts/validate-catalog-schema.ts",
    "validate:bao-dependency-closure": "bun run ./scripts/validate-bao-dependency-closure.ts",
    "validate:local-archive-closure": "bun run ./scripts/validate-local-archive-closure.ts",
    "validate:release-debt": "bun run ./scripts/validate-release-debt.ts",
    "validate:all": "bun run ./scripts/validate.ts all",
    "validate:strict": "bun run validate:all",
    "validate:no-checkedin-bao": "bun run ./scripts/validate.ts no-checkedin-bao",
    "validate:no-monoliths": "bun run ./scripts/validate.ts no-monoliths",
    "validate:no-raw-design-tokens": "bun run ./scripts/validate.ts no-raw-design-tokens",
    "validate:no-local-styles": "bun run ./scripts/validate.ts no-local-styles",
    "validate:no-hardcoded-user-strings": "bun run ./scripts/validate.ts no-hardcoded-user-strings",
    "validate:i18n-parity": "bun run ./scripts/validate.ts i18n-parity",
    "validate:no-direct-route-literals": "bun run ./scripts/validate.ts no-direct-route-literals",
    "validate:no-direct-env-access": "bun run ./scripts/validate.ts no-direct-env-access",
    "validate:no-client-fetch-drift": "bun run ./scripts/validate.ts no-client-fetch-drift",
