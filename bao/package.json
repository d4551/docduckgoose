    "./gates/package-repos-parity": "./src/gates/package-repos-parity.ts",
    "./gates/per-package-verify": "./src/gates/per-package-verify.ts",
    "./gates/registry-consumption": "./src/gates/registry-consumption.ts",
    "./gates/runtime-consumption": "./src/gates/runtime-consumption.ts",
    "./gates/validators/allowlists": "./src/gates/validators/allowlists.ts",
    "./gates/validators/context": "./src/gates/validators/context.ts",
    "./gates/validators/helpers": "./src/gates/validators/helpers.ts",
    "./gates/validators/patterns": "./src/gates/validators/patterns.ts",
    "./gates/validators/rules": "./src/gates/validators/rules.ts",
    "./gates/validators/rules/accessibility-landmarks": "./src/gates/validators/rules/accessibility-landmarks.ts",
    "./gates/validators/rules/bao-archive-policy": "./src/gates/validators/rules/bao-archive-policy.ts",
    "./gates/validators/rules/form-label-controls": "./src/gates/validators/rules/form-label-controls.ts",
    "./gates/validators/rules/htmx-form-contracts": "./src/gates/validators/rules/htmx-form-contracts.ts",
    "./gates/validators/rules/htmx-swap-completeness": "./src/gates/validators/rules/htmx-swap-completeness.ts",
    "./gates/validators/rules/i18n-key-usage": "./src/gates/validators/rules/i18n-key-usage.ts",
    "./gates/validators/rules/i18n-parity": "./src/gates/validators/rules/i18n-parity.ts",
    "./gates/validators/rules/monolith-body-scan": "./src/gates/validators/rules/monolith-body-scan.ts",
    "./gates/validators/rules/monolith-char": "./src/gates/validators/rules/monolith-char.ts",
