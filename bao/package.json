    "./gates/validators/rules/no-arbitrary-spacing": "./src/gates/validators/rules/no-arbitrary-spacing.ts",
    "./gates/validators/rules/no-banned-colors": "./src/gates/validators/rules/no-banned-colors.ts",
    "./gates/validators/rules/no-bare-try-catch": "./src/gates/validators/rules/no-bare-try-catch.ts",
    "./gates/validators/rules/no-client-fetch-drift": "./src/gates/validators/rules/no-client-fetch-drift.ts",
    "./gates/validators/rules/no-console": "./src/gates/validators/rules/no-console.ts",
    "./gates/validators/rules/no-dead-exports": "./src/gates/validators/rules/no-dead-exports.ts",
    "./gates/validators/rules/no-debug-markers": "./src/gates/validators/rules/no-debug-markers.ts",
    "./gates/validators/rules/no-direct-env-access": "./src/gates/validators/rules/no-direct-env-access.ts",
    "./gates/validators/rules/no-direct-route-literals": "./src/gates/validators/rules/no-direct-route-literals.ts",
    "./gates/validators/rules/no-fallback-shims": "./src/gates/validators/rules/no-fallback-shims.ts",
    "./gates/validators/rules/no-hardcoded-user-strings": "./src/gates/validators/rules/no-hardcoded-user-strings.ts",
    "./gates/validators/rules/no-retired-patterns": "./src/gates/validators/rules/no-retired-patterns.ts",
    "./gates/validators/rules/no-local-styles": "./src/gates/validators/rules/no-local-styles.ts",
    "./gates/validators/rules/no-monoliths": "./src/gates/validators/rules/no-monoliths.ts",
    "./gates/validators/rules/no-node-imports": "./src/gates/validators/rules/no-node-imports.ts",
    "./gates/validators/rules/no-raw-design-tokens": "./src/gates/validators/rules/no-raw-design-tokens.ts",
    "./gates/validators/rules/no-schema-duplication": "./src/gates/validators/rules/no-schema-duplication.ts",
    "./gates/validators/rules/no-ts-ignore": "./src/gates/validators/rules/no-ts-ignore.ts",
    "./gates/validators/rules/no-unknown-casts": "./src/gates/validators/rules/no-unknown-casts.ts",
    "./gates/validators/rules/no-unsafe-storage": "./src/gates/validators/rules/no-unsafe-storage.ts",
    "./gates/validators/rules/page-state-contracts": "./src/gates/validators/rules/page-state-contracts.ts",
    "./gates/validators/rules/seo-contracts": "./src/gates/validators/rules/seo-contracts.ts",
    "./logger": "./src/logger.ts",
    "./manifest": "./src/manifest.ts",
    "./package-json": "./src/package-json.ts",
    "./readme": "./src/readme.ts",
    "./readme-contract": "./src/readme-contract.ts",
    "./readme-context": "./src/readme-context.ts",
    "./readme-merge": "./src/readme-merge.ts",
    "./readme-overrides": "./src/readme-overrides.ts",
    "./scripts/lib/build-bao-archive": "./scripts/lib/build-bao-archive.ts",
    "./scripts/lib/local-archive-parity": "./scripts/lib/local-archive-parity.ts",
    "./scripts/lib/schema-guards": "./scripts/lib/schema-guards.ts",
