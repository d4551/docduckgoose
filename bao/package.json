    "validate:no-unsafe-storage": "bun run ./scripts/validate.ts no-unsafe-storage",
    "validate:page-state-contracts": "bun run ./scripts/validate.ts page-state-contracts",
    "validate:seo-contracts": "bun run ./scripts/validate.ts seo-contracts",
    "validate:accessibility-landmarks": "bun run ./scripts/validate.ts accessibility-landmarks",
    "validate:bao-archive-policy": "bun run ./scripts/validate.ts bao-archive-policy",
    "validate:no-dead-exports": "bun run ./scripts/validate.ts no-dead-exports",
    "validate:no-fallback-shims": "bun run ./scripts/validate.ts no-fallback-shims",
    "verify": "bun run typecheck && bun run lint && bun test && bun run bao:build && bun run bao:validate && bun run validate:no-workspace-deps && bun run validate:catalog-schema && bun run validate:catalog-drift && bun run validate:registry-parity && bun run validate:manifest-parity && bun run validate:registry-consumption && bun run validate:runtime-consumption && bun run validate:package-repos-parity && bun run validate:no-workspace-package-hoarding && bun run validate:bao-dependency-closure && bun run validate:release-debt && bun run validate:readme-contract && bun run validate:strict",
    "validate:catalog-drift": "bun run ./scripts/validate-catalog-drift.ts",
    "reconcile:catalog-drift": "bun run ./scripts/reconcile-catalog-drift.ts",
    "sync-package-readmes": "bun run ./scripts/sync-package-readmes.ts",
    "validate:readme-contract": "bun run ./scripts/validate-readme-contract.ts"
  },
  "dependencies": {
    "@baohaus/bao-contracts": "file:../bao-source/bao-contracts",
    "@baohaus/bao-schemas": "file:../bao-source/bao-schemas",
    "@baohaus/bao-utils": "file:../bao-source/bao-utils"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "1.3.13",
    "typescript": "6.0.3"
  },
  "exports": {
