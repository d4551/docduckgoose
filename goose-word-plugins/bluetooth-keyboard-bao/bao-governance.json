{
  "schemaVersion": 1,
  "id": "bluetooth-keyboard-bao",
  "name": "@baohaus/bluetooth-keyboard-bao",
  "version": "0.1.0",
  "identity": {
    "id": "bluetooth-keyboard-bao",
    "packageName": "@baohaus/bluetooth-keyboard-bao",
    "packageVersion": "0.1.0"
  },
  "channel": "local",
  "visibility": "private",
  "description": "Bluetooth keyboard support plugin for Goose Word. Enables Web Bluetooth (BLE HID) pairing and status.",
  "copyFirst": {
    "required": true,
    "installRoot": "~/.goose-word/bao/bluetooth-keyboard-bao",
    "archivePolicy": "no-prebuilt-archives"
  },
  "targets": [
    {
      "kind": "settings-tab",
      "entrypoint": "dist/bao-extensions/settings-tab.js"
    },
    {
      "kind": "elysia-plugin",
      "entrypoint": "dist/bao-extensions/elysia-plugin.js"
    }
  ]
}
